# Copy this file to .env.local and fill in your values.

# ─── WordPress Base ───────────────────────────────────────────────────────────
WP_BASE=https://your-wordpress-site.com

# ─── WordPress AJAX (auth / custom AJAX actions) ──────────────────────────────
WP_AJAX_URL=https://your-wordpress-site.com/wp-admin/admin-ajax.php

# ─── WooCommerce REST API ─────────────────────────────────────────────────────
WP_WC_URL=https://your-wordpress-site.com/wp-json/wc/v3

# ─── Custom REST Endpoints ────────────────────────────────────────────────────
WP_CUSTOM_URL=https://your-wordpress-site.com/wp-json/custom/v1
WP_CUSTOM_API_URL=https://your-wordpress-site.com/wp-json/custom-api/v1

# ─── WooCommerce API Keys — Read (products, variations) ──────────────────────
WC_KEY=ck_your_read_key_here
WC_SECRET=cs_your_read_secret_here

# ─── WooCommerce API Keys — Write (create orders) ────────────────────────────
WC_ORDERS_KEY=ck_your_orders_key_here
WC_ORDERS_SECRET=cs_your_orders_secret_here
